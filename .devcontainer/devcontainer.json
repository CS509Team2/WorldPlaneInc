{
  "name": "WorldPlaneInc",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "editorconfig.editorconfig",
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "cweijan.vscode-mysql-client2"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },
  "postCreateCommand": "sudo apt update && sudo apt-get install -y default-mysql-client",
  "postStartCommand": ".devcontainer/setup-db.sh"
}